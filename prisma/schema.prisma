generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Volunteer {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  phone        String
  college      String
  skills       String
  availability String
  motivation   String
  createdAt    DateTime @default(now())
}